#include <stdio.h>
#include <string.h>
#include <ctype.h>
#include "freertos/FreeRTOS.h"
#include "freertos/task.h"
#include "driver/gpio.h"
#include "esp_timer.h"

#define BANNER_NAME  "regino alvarado ruiz"



#define SA    5
#define SB    4
#define SC    19
#define SD    25
#define SE    26
#define SF    33
#define SG    32
#define SP    14


#define DIG1  22
#define DIG2  21
#define DIG3  15
#define DIG4  2

#define WAIT_2   15    
#define WAIT    300    


#define NUM_DIGITS  4

#define SEG(a,b,c,d,e,f,g)  (uint8_t)(((a)<<7)|((b)<<6)|((c)<<5)|((d)<<4)|((e)<<3)|((f)<<2)|((g)<<1))
static const uint8_t siekoo_A_Z[26] = {
    SEG(1,1,1,1,1,0,1),  /* A */
    SEG(0,0,1,1,1,1,1),  /* B */
    SEG(0,0,0,1,1,0,1),  /* C */
    SEG(0,1,1,1,1,0,1),  /* D */
    SEG(1,0,0,1,1,1,1),  /* E */
    SEG(1,0,0,0,1,1,1),  /* F */
    SEG(1,0,1,1,1,1,0),  /* G */
    SEG(0,0,1,0,1,1,1),  /* H */
    SEG(1,0,0,0,1,0,0),  /* I */
    SEG(1,0,1,1,0,0,0),  /* J */
    SEG(1,0,1,0,1,1,1),  /* K */
    SEG(0,0,0,1,1,1,0),  /* L */
    SEG(1,0,1,0,1,0,1),  /* M */
    SEG(0,0,1,0,1,0,1),  /* N */
    SEG(0,0,1,1,1,0,1),  /* O */
    SEG(1,1,0,0,1,1,1),  /* P */
    SEG(1,1,1,0,0,1,1),  /* Q */
    SEG(0,0,0,0,1,0,1),  /* R */
    SEG(1,0,1,1,0,1,0),  /* S */
    SEG(0,0,0,1,1,1,1),  /* T */
    SEG(0,0,1,1,1,0,0),  /* U */
    SEG(0,1,0,1,0,1,0),  /* V */
    SEG(0,1,0,1,0,1,1),  /* W */
    SEG(0,0,1,0,1,0,0),  /* X */
    SEG(0,1,1,1,0,1,1),  /* Y */
    SEG(1,1,0,1,1,0,0),  /* Z */
};

static const uint8_t siekoo_0_9[10] = {
    SEG(1,1,1,1,1,1,0),  /* 0 */
    SEG(0,1,1,0,0,0,0),  /* 1 */
    SEG(1,1,0,1,1,0,1),  /* 2 */
    SEG(1,1,1,1,0,0,1),  /* 3 */
    SEG(0,1,1,0,0,1,1),  /* 4 */
    SEG(1,0,1,1,0,1,1),  /* 5 */
    SEG(1,0,1,1,1,1,1),  /* 6 */
    SEG(1,1,1,0,0,0,0),  /* 7 */
    SEG(1,1,1,1,1,1,1),  /* 8 */
    SEG(1,1,1,1,0,1,1),  /* 9 */
};

#define SEG_OFF  0x00   /* dígito apagado */

static uint8_t char_to_siekoo(char c)
{
    if (c >= 'A' && c <= 'Z') return siekoo_A_Z[c - 'A'];
    if (c >= 'a' && c <= 'z') return siekoo_A_Z[c - 'a'];
    if (c >= '0' && c <= '9') return siekoo_0_9[c - '0'];
    if (c == ' ')              return SEG_OFF;
    return SEG_OFF; 
}


static const int segPins[8] = { SA, SB, SC, SD, SE, SF, SG, SP };
static const int digPins[4] = { DIG1, DIG2, DIG3, DIG4 };

static volatile uint8_t display_buf[NUM_DIGITS] = {0, 0, 0, 0};


static void gpio_init_all(void)
{
    for (int i = 0; i < 8; i++) {
        gpio_reset_pin(segPins[i]);
        gpio_set_direction(segPins[i], GPIO_MODE_OUTPUT);
        gpio_set_level(segPins[i], 0); 
    }
    for (int i = 0; i < NUM_DIGITS; i++) {
        gpio_reset_pin(digPins[i]);
        gpio_set_direction(digPins[i], GPIO_MODE_OUTPUT);
        gpio_set_level(digPins[i], 1); 
    }
}

static void apagar(void)
{
    for (int i = 0; i < NUM_DIGITS; i++)
        gpio_set_level(digPins[i], 1);
}

static void mostrar_digito(int pos, uint8_t segByte)
{
    apagar();

    for (int s = 0; s < 8; s++) {
        int on = (segByte >> (7 - s)) & 0x01;
        gpio_set_level(segPins[s], on);
    }

    gpio_set_level(digPins[pos], 0);

    vTaskDelay(pdMS_TO_TICKS(WAIT_2));

    gpio_set_level(digPins[pos], 1);
}

static void multiplex_task(void *arg)
{
    while (1) {
        for (int d = 0; d < NUM_DIGITS; d++) {
            mostrar_digito(d, display_buf[d]);
        }
    }
}


static void banner_task(void *arg)
{
    const char *name = BANNER_NAME;
    int name_len = strlen(name);

    uint8_t siekoo_buf[64];
    if (name_len > 64) name_len = 64;
    for (int i = 0; i < name_len; i++) {
        siekoo_buf[i] = char_to_siekoo(name[i]);
    }


    int total_steps = name_len + NUM_DIGITS;

    while (1) {
        for (int offset = 0; offset < total_steps; offset++) {
            for (int d = 0; d < NUM_DIGITS; d++) {
              
                int idx = offset - (NUM_DIGITS - 1 - d);
                if (idx >= 0 && idx < name_len) {
                    display_buf[d] = siekoo_buf[idx];
                } else {
                    display_buf[d] = SEG_OFF;
                }
            }
            vTaskDelay(pdMS_TO_TICKS(WAIT));
        }
    }
}


void app_main(void)
{
    gpio_init_all();

    xTaskCreatePinnedToCore(
        multiplex_task, "multiplex",
        2048, NULL, 5, NULL, 1
    );

    xTaskCreatePinnedToCore(
        banner_task, "banner",
        4096, NULL, 3, NULL, 0
    );
}
